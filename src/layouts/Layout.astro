---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Portfolio profesional de Juan Carlos Olmedo - Líder de Operaciones IT, Analista de Datos y Desarrollador de Soluciones" />
    <meta name="theme-color" content="#0b0f19" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <title>{title}</title>
  </head>
  <body>
    <div class="noise"></div>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>