---
const resumen = `Apasionado por la tecnología, el desarrollo y la optimización de procesos. Me especializo en liderar equipos de alto rendimiento, solucionar problemas complejos y diseñar soluciones que automaticen y mejoren la gestión operativa. Cuento con sólida experiencia combinando soporte técnico avanzado, análisis de datos y scripting.`;

const especializaciones = [
  { titulo: 'Liderazgo IT', desc: 'Gestión de equipos de alto rendimiento', icon: 'fa-users-gear' },
  { titulo: 'Análisis de Datos', desc: 'PowerBI, SQL, Reporting', icon: 'fa-chart-pie' },
  { titulo: 'Automatización', desc: 'PowerShell, Python, Scripts', icon: 'fa-robot' },
  { titulo: 'Soporte Técnico', desc: 'SCCM, Active Directory', icon: 'fa-server' }
];
---

<section id="sobre-mi" class="sobre-mi">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">
        <span class="title-accent">#</span> Sobre Mí
      </h2>
      <p class="section-subtitle">Conoce más sobre mi trayectoria y enfoque profesional</p>
    </div>
    
    <div class="resumen-card">
      <p class="resumen-text">{resumen}</p>
      
      <div class="especializaciones">
        {especializaciones.map((espec, index) => (
          <div class="espec-item-3d" data-index={index} style={`animation-delay: ${index * 0.1}s`}>
            <div class="card-glow"></div>
            <div class="card-shine"></div>
            <div class="espec-content">
              <div class="espec-icon">
                <i class={`fa-solid ${espec.icon}`}></i>
              </div>
              <div class="espec-header">
                <span class="espec-num">0{index + 1}</span>
                <h4>{espec.titulo}</h4>
              </div>
              <p>{espec.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .sobre-mi {
    background: var(--primary);
    position: relative;
  }

  .section-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .section-title {
    font-size: 2.5rem;
    color: var(--text);
    margin-bottom: 12px;
  }

  .title-accent {
    color: var(--accent);
    font-family: 'JetBrains Mono', monospace;
  }

  .section-subtitle {
    color: var(--text-muted);
  }

  .resumen-card {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .resumen-text {
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--text-muted);
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .especializaciones {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .espec-item-3d {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 24px 20px;
    text-align: center;
    animation: slideUp 0.5s ease-out both;
    opacity: 0;
    position: relative;
    overflow: hidden;
    transform-style: preserve-3d;
    transform: perspective(1000px) rotateX(0deg) rotateY(0deg);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-theme="light"] .espec-item-3d {
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    border-color: rgba(0, 0, 0, 0.08);
  }

  .espec-item-3d:hover {
    transform: perspective(1000px) rotateX(2deg) rotateY(-2deg);
  }

  .card-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--accent-secondary));
    transform: scaleX(0);
    transition: transform 0.3s ease;
  }

  .espec-item-3d:hover .card-glow {
    transform: scaleX(1);
  }

  .card-shine {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.03),
      transparent
    );
    transition: left 0.5s ease;
    pointer-events: none;
  }

  .espec-item-3d:hover .card-shine {
    left: 100%;
  }

  .espec-content {
    position: relative;
    z-index: 1;
    transform: translateZ(20px);
  }

  .espec-icon {
    width: 50px;
    height: 50px;
    margin: 0 auto 16px;
    background: rgba(34, 211, 238, 0.1);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    color: var(--accent);
    transition: all 0.3s ease;
  }

  .espec-item-3d:hover .espec-icon {
    background: linear-gradient(135deg, var(--accent-tertiary) 0%, var(--accent) 100%);
    color: var(--primary);
    transform: scale(1.1) rotate(-5deg);
    box-shadow: 0 0 20px rgba(34, 211, 238, 0.3);
  }

  .espec-item-3d::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 15px;
    padding: 1px;
    background: linear-gradient(
      135deg,
      rgba(34, 211, 238, 0.3),
      transparent,
      rgba(129, 140, 248, 0.3)
    );
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .espec-item-3d:hover::before {
    opacity: 1;
  }

  .espec-item-3d::after {
    content: '';
    position: absolute;
    top: 15%;
    left: 15%;
    width: 25%;
    height: 25%;
    background: radial-gradient(circle, rgba(34, 211, 238, 0.15) 0%, transparent 70%);
    filter: blur(15px);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .espec-item-3d:hover::after {
    opacity: 1;
  }

  .espec-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-bottom: 8px;
  }

  .espec-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--accent);
    opacity: 0.6;
  }

  .espec-header h4 {
    font-size: 0.95rem;
    color: var(--text);
  }

  .espec-item-3d p {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 900px) {
    .especializaciones {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .especializaciones {
      grid-template-columns: 1fr;
    }
    .espec-item-3d:hover {
      transform: none;
    }
  }
</style>

<script>
  const cards = document.querySelectorAll('.espec-item-3d');

  cards.forEach(card => {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = (y - centerY) / 20;
      const rotateY = (centerX - x) / 20;
      card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
    });

    card.addEventListener('mouseleave', () => {
      card.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg)';
    });
  });
</script>